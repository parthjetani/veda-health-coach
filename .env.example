# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=          # Meta System User permanent token
WHATSAPP_PHONE_NUMBER_ID=       # From Meta Business Suite → WhatsApp → Phone Numbers
WHATSAPP_VERIFY_TOKEN=          # Any random string you choose for webhook verification
WHATSAPP_APP_SECRET=            # Meta App Secret (Settings -> Basic -> App Secret) for webhook signature verification

# Google Gemini
GEMINI_API_KEY=                 # From aistudio.google.com -> Get API Key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.3

# Supabase
SUPABASE_URL=                   # https://xxxx.supabase.co (from Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY=      # Project Settings → API → service_role (NOT the anon key)

# Admin
ADMIN_API_KEY=                  # Any long random string — guards admin endpoints

# App
CORS_ORIGINS=*                  # comma-separated origins for admin dashboard, or "*" for all
ENVIRONMENT=development         # development | production
